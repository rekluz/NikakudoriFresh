<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 1. The Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D1A3A</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Transitions to the clean theme name below -->
        <item name="postSplashScreenTheme">@style/Theme.NikakudoriMahjong</item>
    </style>

    <!-- 2. The Main Game Theme (Renamed for consistency) -->
    <style name="Theme.NikakudoriMahjong" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">#0D1A3A</item>
        <item name="android:windowNoTitle">true</item>

        <!-- S24/Display Cutout Optimization -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>